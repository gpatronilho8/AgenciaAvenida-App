{
  "name": "Ocorrencia",
  "type": "object",
  "properties": {
    "condominio_id": {
      "type": "string"
    },
    "fracao_id": {
      "type": "string",
      "description": "Fra\u00e7\u00e3o ou \u00e1rea comum"
    },
    "reportada_por": {
      "type": "string",
      "description": "Pessoa que reportou"
    },
    "titulo": {
      "type": "string"
    },
    "descricao": {
      "type": "string"
    },
    "tipo": {
      "type": "string",
      "enum": [
        "avaria",
        "manutencao",
        "limpeza",
        "seguranca",
        "outro"
      ]
    },
    "prioridade": {
      "type": "string",
      "enum": [
        "baixa",
        "media",
        "alta",
        "urgente"
      ],
      "default": "media"
    },
    "estado": {
      "type": "string",
      "enum": [
        "aberta",
        "em_progresso",
        "resolvida",
        "fechada"
      ],
      "default": "aberta"
    },
    "data_abertura": {
      "type": "string",
      "format": "date"
    },
    "data_resolucao": {
      "type": "string",
      "format": "date"
    },
    "fornecedor_id": {
      "type": "string"
    },
    "custo_estimado": {
      "type": "number"
    },
    "custo_real": {
      "type": "number"
    },
    "area": {
      "type": "string",
      "enum": [
        "fracao",
        "hall",
        "escadas",
        "garagem",
        "jardim",
        "cobertura",
        "elevador",
        "outro"
      ]
    },
    "observacoes": {
      "type": "string"
    },
    "foto_url": {
      "type": "string"
    }
  },
  "required": [
    "condominio_id",
    "titulo",
    "tipo"
  ]
}