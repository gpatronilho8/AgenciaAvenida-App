{
  "name": "DespesaPropriedade",
  "type": "object",
  "properties": {
    "propriedade_id": {
      "type": "string"
    },
    "renda_mensal_id": {
      "type": "string",
      "description": "Associada a um m\u00eas espec\u00edfico (opcional)"
    },
    "descricao": {
      "type": "string"
    },
    "categoria": {
      "type": "string",
