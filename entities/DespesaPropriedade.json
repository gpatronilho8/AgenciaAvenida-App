    },
    "data": {
      "type": "string",
      "format": "date"
    },
    "fornecedor_id": {
      "type": "string"
    },
    "documento_url": {
      "type": "string"
    },
    "desconta_proprietario": {
      "type": "boolean",
      "default": true,
      "description": "Se desconta no repasse ao propriet\u00e1rio"
    },
    "notas": {
      "type": "string"
    }
