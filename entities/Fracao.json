{
  "name": "Fracao",
  "type": "object",
  "properties": {
    "condominio_id": {
      "type": "string",
      "description": "ID do condomínio"
    },
    "codigo_fracao": {
      "type": "string",
      "description": "Ex: A1, B2, 1Dto"
    },
    "descricao_piso_lado": {
      "type": "string",
      "description": "Ex: Apartamento T2"
    },
    "permilagem": {
      "type": "number",
      "description": "Permilagem da fração"
    },
    "proprietario_id": {
      "type": "string"
    },
    "proprietario2_id": {
      "type": "string"
    },
    "inquilino_id": {
      "type": "string"
    },
    "inquilino2_id": {
      "type": "string"
    },
    "recibo_incluir": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "proprietario",
          "proprietario2",
          "inquilino",
          "inquilino2"
        ]
      },
      "description": "Quais os titulares a incluir no recibo"
    },
    "pessoa_contacto": {
      "type": "string"
    },
    "quota_mensal": {
      "type": "number",
      "default": 0
    },
    "ativa": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "condominio_id",
    "codigo_fracao"
  ]
}