{
  "name": "ProcessoJudicial",
  "type": "object",
  "properties": {
    "condominio_id": {
      "type": "string"
    },
    "fracao_id": {
      "type": "string"
    },
    "pessoa_id": {
      "type": "string",
      "description": "Devedor"
    },
    "advogado_id": {
      "type": "string",
      "description": "ID do advogado (Pessoa)"
    },
    "descricao": {
      "type": "string"
    },
    "valor_divida": {
      "type": "number",
      "default": 0
    },
    "fase": {
      "type": "string",
      "enum": [
        "carta_normal",
        "carta_registada_ar",
        "carta_advogado",
        "processo_judicial",
        "encerrado"
      ],
      "default": "carta_normal"
    },
    "resposta_inquilino": {
      "type": "string",
      "enum": [
        "nao_responde",
        "carta_devolvida",
        "negociacao",
        "divida_paga",
        "plano_pagamento"
      ]
    },
    "data_inicio": {
      "type": "string",
      "format": "date"
    },
    "data_encerramento": {
      "type": "string",
      "format": "date"
    },
    "notas": {
      "type": "string"
    },
    "custos": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "fase": {
            "type": "string"
          },
          "descricao": {
            "type": "string"
          },
          "valor": {
            "type": "number"
          },
          "data": {
            "type": "string"
          },
          "despesa_lancada": {
            "type": "boolean",
            "default": false
          },
          "despesa_id": {
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "condominio_id",
    "pessoa_id"
  ]
}