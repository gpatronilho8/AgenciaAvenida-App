{
  "name": "ConfiguracaoQuota",
  "type": "object",
  "properties": {
    "condominio_id": {
      "type": "string"
    },
    "tipo_calculo": {
      "type": "string",
      "enum": [
        "fixo",
        "permilagem"
      ],
      "default": "fixo",
      "description": "Quota fixa ou calculada por permilagem"
    },
    "valor_fixo": {
      "type": "number",
      "default": 0,
      "description": "Valor fixo por fra\u00e7\u00e3o"
    },
    "valor_total_permilagem": {
      "type": "number",
      "default": 0,
      "description": "Valor total a distribuir por permilagem"
    },
    "dia_vencimento": {
      "type": "number",
      "default": 8,
      "description": "Dia do m\u00eas para vencimento"
    },
    "mes_inicio": {
      "type": "number",
      "default": 1,
      "description": "M\u00eas de in\u00edcio de contagem (1-12)"
    },
    "ano_inicio": {
      "type": "number",
      "description": "Ano de in\u00edcio"
    },
