{
  "name": "Processo",
  "type": "object",
  "properties": {
    "tipo": {
      "type": "string",
      "enum": [
        "irs",
        "carta_conducao",
        "passaporte",
        "nif",
        "niss",
        "reagrupamento_familiar",
        "visto",
        "licenca",
        "certidao",
        "procuracao",
        "outro"
      ]
    },
    "tipo_personalizado": {
      "type": "string",
      "description": "Usado quando tipo = outro"
    },
    "pessoa_id": {
      "type": "string"
    },
    "atribuido_a": {
      "type": "string",
      "description": "ID do utilizador staff ao qual o processo está atribuído"
    },
    "descricao": {
      "type": "string"
    },
    "custo_servico": {
      "type": "number",
      "default": 0
    },
    "pago": {
      "type": "boolean",
      "default": false
    },
    "data_pagamento": {
      "type": "string",
      "format": "date"
    },
    "metodo_pagamento": {
      "type": "string",
      "enum": [
        "transferencia_bancaria",
        "numerario",
        "debito_direto",
        "cheque"
      ]
    },
    "estado": {
      "type": "string",
      "enum": [
        "pendente_inicio",
        "em_curso",
        "pendente_cliente",
        "aguarda_documentos",
        "pendente_entidade_externa",
        "concluido",
        "cancelado"
      ],
      "default": "pendente_inicio"
    },
    "data_inicio": {
      "type": "string",
      "format": "date"
    },
    "data_conclusao": {
      "type": "string",
      "format": "date"
    },
    "data_prazo": {
      "type": "string",
      "format": "date"
    },
    "documentos": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "nome": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      }
    },
    "notas": {
      "type": "string"
    },
    "prioridade": {
      "type": "string",
      "enum": [
        "normal",
        "urgente"
      ],
      "default": "normal"
    },
    "irs_estado": {
      "type": "string",
      "enum": [
        "recebida_documentacao",
        "submetido_at_prova",
        "comprovativo_enviado_cliente",
        "submetida_substituicao_at"
      ],
      "description": "Estado específico IRS"
    },
    "irs_campos": {
      "type": "object",
      "description": "Checkboxes de atributos IRS",
      "properties": {
        "estado_civil_solteiro": {
          "type": "boolean",
          "default": false
        },
        "estado_civil_casado": {
          "type": "boolean",
          "default": false
        },
        "estado_civil_separado": {
          "type": "boolean",
          "default": false
        },
        "rendimentos_prediais": {
          "type": "boolean",
          "default": false
        },
        "incapacidade": {
          "type": "boolean",
          "default": false
        },
        "irs_jovem": {
          "type": "boolean",
          "default": false
        },
        "declaracao_substituicao": {
          "type": "boolean",
          "default": false
        },
        "rendimentos_estrangeiro": {
          "type": "boolean",
          "default": false
        }
      }
    }
  },
  "required": [
    "tipo",
    "pessoa_id"
  ]
}