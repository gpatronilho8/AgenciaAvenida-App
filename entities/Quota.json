{
  "name": "Quota",
  "type": "object",
  "properties": {
    "condominio_id": {
      "type": "string"
    },
    "fracao_id": {
      "type": "string"
    },
    "pessoa_id": {
      "type": "string",
      "description": "Responsável pelo pagamento"
    },
    "tipo": {
      "type": "string",
      "enum": [
        "mensal",
        "extraordinaria"
      ],
      "default": "mensal"
    },
    "descricao": {
      "type": "string"
    },
    "valor": {
      "type": "number"
    },
    "data_emissao": {
      "type": "string",
      "format": "date"
    },
    "data_vencimento": {
      "type": "string",
      "format": "date"
    },
    "data_pagamento": {
      "type": "string",
      "format": "date"
    },
    "estado": {
      "type": "string",
      "enum": [
        "em_aberto",
        "pago",
        "vencido",
        "anulado"
      ],
      "default": "em_aberto"
    },
    "metodo_pagamento": {
      "type": "string",
      "enum": [
        "transferencia_bancaria",
        "numerario",
        "debito_direto",
        "cheque"
      ]
    },
    "numero_recibo": {
      "type": "string"
    },
    "ano": {
      "type": "number"
    },
    "mes": {
      "type": "number"
    },
    "observacoes": {
      "type": "string"
    }
  },
  "required": [
    "condominio_id",
    "fracao_id",
    "valor",
    "data_emissao"
  ]
}