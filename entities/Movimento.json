{
  "name": "Movimento",
  "type": "object",
  "properties": {
    "condominio_id": {
      "type": "string"
    },
    "tipo": {
      "type": "string",
      "enum": [
        "receita",
        "despesa"
      ],
      "default": "despesa"
    },
    "categoria": {
      "type": "string",
      "enum": [
        "quotas",
        "limpeza",
        "manutencao_obras",
        "seguros",
        "eletricidade",
        "agua",
        "elevador",
        "recuperacao_divida",
        "piscina",
        "acerto_contabilistico",
        "despesas_administrativas",
        "despesas_bancarias",
        "despesas_juridicas",
        "outros"
      ]
    },
    "descricao": {
      "type": "string"
    },
    "valor": {
      "type": "number"
    },
    "data": {
      "type": "string",
      "format": "date"
    },
    "conta": {
      "type": "string",
      "enum": [
        "banco",
        "caixa"
      ]
    },
    "metodo_pagamento": {
      "type": "string",
      "enum": [
        "transferencia_bancaria",
        "numerario",
        "debito_direto",
        "cheque"
      ]
    },
    "referencia_id": {
      "type": "string",
      "description": "ID da quota ou despesa relacionada"
    },
    "fornecedor_id": {
      "type": "string"
    },
    "numero_documento": {
      "type": "string"
    },
    "observacoes": {
      "type": "string"
    }
  },
  "required": [
    "condominio_id",
    "tipo",
    "valor",
    "data",
    "descricao"
  ]
}