{
  "name": "Propriedade",
  "type": "object",
  "properties": {
    "morada": {
      "type": "string",
      "description": "Morada completa da propriedade"
    },
    "codigo_postal": {
      "type": "string"
    },
    "localidade": {
      "type": "string"
    },
    "tipo": {
      "type": "string",
      "enum": [
        "apartamento",
        "moradia",
        "loja",
        "escritorio",
        "garagem",
        "armazem",
        "outro"
      ],
      "default": "apartamento"
    },
    "proprietario_id": {
      "type": "string",
      "description": "ID da pessoa propriet\u00e1ria"
    },
    "inquilino_id": {
      "type": "string",
      "description": "ID da pessoa inquilina"
    },
    "renda_mensal": {
      "type": "number",
      "default": 0
    },
    "comissao_agencia": {
      "type": "number",
      "default": 0,
      "description": "Valor fixo ou % da agência"
    },
    "comissao_percentagem": {
      "type": "boolean",
      "default": false,
      "description": "Se true, comissão é em %"
    },
    "dia_vencimento": {
      "type": "number",
      "default": 8,
      "description": "Dia do mês para vencimento"
    },
    "ativa": {
      "type": "boolean",
      "default": true
    },
    "notas": {
      "type": "string"
    }
  },
  "required": [
    "morada",
    "proprietario_id"
  ]
}